<Page x:Class="WorkSchedule.Views.Pages.ManualSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource BackgroundBrush}"
      FlowDirection="RightToLeft">

    <Page.Resources>
        <Style x:Key="EmployeeChipStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" CornerRadius="20" BorderThickness="1.5"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#E2E8F0" Background="White">
                            <TextBlock x:Name="Txt" Text="{Binding DisplayLabel}"
                                       FontSize="13" FontFamily="Segoe UI"
                                       Foreground="#1E293B" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3B82F6"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                <Setter TargetName="Txt" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Info bar -->
            <RowDefinition Height="*"/>      <!-- Schedule grid -->
            <RowDefinition Height="Auto"/>   <!-- Employee chips -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="Save_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Padding="20,10" FontSize="13" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                        <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="שמור סידור" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Click="BackToBlocking_Click"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Padding="16,10" FontSize="13" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                        <materialDesign:PackIcon Kind="ShieldEditOutline" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="עריכת חסימות" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="2" FlowDirection="RightToLeft"
                            VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="שיבוץ ידני" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="לחץ על עובד ואז על משבצת לשיבוץ — לחיצה ימנית לעריכת טקסט חופשי"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Info bar: selected employee ── -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,10">
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock x:Name="NoEmpHint" Text="← בחר עובד מהחיפים"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Border x:Name="SelectedEmpBadge" Visibility="Collapsed"
                        Background="#EFF6FF" BorderBrush="#3B82F6" BorderThickness="1.5"
                        CornerRadius="22" Padding="10,5,14,5">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="26" Height="26" CornerRadius="13" Background="#3B82F6"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock x:Name="SelectedEmpInitial" Text=""
                                       Foreground="White" FontWeight="Bold" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="SelectedEmployeeLabel" Text=""
                                   FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ── Schedule grid ── -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ContentPresenter x:Name="ScheduleGridHost" Margin="24,20"/>
        </ScrollViewer>

        <!-- ── Employee chips ── -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="עובדים:" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ListBox x:Name="EmployeeChips"
                             BorderThickness="0" Background="Transparent"
                             SelectionChanged="EmployeeChip_SelectionChanged"
                             ItemContainerStyle="{StaticResource EmployeeChipStyle}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── Save name overlay ── -->
        <Grid x:Name="SaveOverlay" Grid.RowSpan="4"
              Visibility="Collapsed" Background="#88000000">
            <materialDesign:Card Width="400" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Padding="28" materialDesign:ElevationAssist.Elevation="Dp8"
                                 FlowDirection="RightToLeft">
                <StackPanel>
                    <TextBlock Text="שמירת סידור" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Text="הכנס שם לסידור (לדוגמה: שבוע 20/04 - 26/04)"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>
                    <TextBox x:Name="SaveNameBox"
                             materialDesign:HintAssist.Hint="שם הסידור..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,24"
                             KeyDown="SaveNameBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="שמור" Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="24,8" Margin="0,0,10,0" Click="SaveConfirm_Click"/>
                        <Button Content="ביטול" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="24,8" Click="SaveCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- ── Free text edit overlay ── -->
        <Grid x:Name="TextEditOverlay" Grid.RowSpan="4"
              Visibility="Collapsed" Background="#88000000">
            <materialDesign:Card Width="380" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Padding="28" materialDesign:ElevationAssist.Elevation="Dp8"
                                 FlowDirection="RightToLeft">
                <StackPanel>
                    <TextBlock x:Name="TextEditTitle" Text="עריכת תא"
                               FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBox x:Name="TextEditBox"
                             materialDesign:HintAssist.Hint="הכנס טקסט (שם עובד, הערה...)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,24"
                             KeyDown="TextEditBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="אישור" Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="24,8" Margin="0,0,10,0" Click="TextEditConfirm_Click"/>
                        <Button Content="ביטול" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="24,8" Click="TextEditCancel_Click"/>
                        <Button Content="נקה תא" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource DangerBrush}"
                                BorderBrush="{StaticResource DangerBrush}"
                                Padding="24,8" Margin="10,0,0,0" Click="TextEditClear_Click"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Page>
