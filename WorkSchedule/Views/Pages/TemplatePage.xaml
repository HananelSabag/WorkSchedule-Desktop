<Page x:Class="WorkSchedule.Views.Pages.TemplatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource BackgroundBrush}"
      FlowDirection="RightToLeft">

    <Page.Resources>
        <!-- Small icon-only button with no min-width constraints -->
        <Style x:Key="TinyIconBtn" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderBrush"      Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="MinWidth"         Value="0"/>
            <Setter Property="MinHeight"        Value="0"/>
            <Setter Property="Width"            Value="26"/>
            <Setter Property="Height"           Value="26"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Body -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="32,20">
            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="SaveTemplate_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Padding="20,10" FontSize="14" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                        <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="שמור תבנית" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            Margin="20,0,0,0" FlowDirection="RightToLeft">
                    <TextBlock Text="מבנה טבלה" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="הגדר משמרות וימי עבודה לפי מקום העבודה שלך"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Body ── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,32">

                <!-- ── Top two columns: [Name+Days] | [Shifts] ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" MinWidth="280"/>   <!-- Name + Days -->
                        <ColumnDefinition Width="20"/>                   <!-- Gap -->
                        <ColumnDefinition Width="*"/>                    <!-- Shifts -->
                    </Grid.ColumnDefinitions>

                    <!-- Left: Template name + Days stacked -->
                    <StackPanel Grid.Column="0">

                        <!-- Template name -->
                        <materialDesign:Card Padding="20,18" Margin="0,0,0,16"
                                             materialDesign:ElevationAssist.Elevation="Dp1">
                            <StackPanel>
                                <TextBlock Text="שם התבנית" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                                <TextBox x:Name="TemplateNameBox"
                                         materialDesign:HintAssist.Hint="לדוגמה: אבטחה, מסעדה..."
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         FontSize="13"
                                         TextChanged="Config_Changed"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Days -->
                        <materialDesign:Card Padding="20,18"
                                             materialDesign:ElevationAssist.Elevation="Dp1">
                            <StackPanel>
                                <TextBlock Text="ימי עבודה" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                <ItemsControl x:Name="DaysList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ToggleButton IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                          Content="{Binding DayNameHebrew}"
                                                          Width="72" Height="34" FontSize="12"
                                                          Margin="0,0,6,6"
                                                          Style="{StaticResource MaterialDesignOutlinedButton}"
                                                          Checked="DayToggle_Changed"
                                                          Unchecked="DayToggle_Changed"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </materialDesign:Card>

                    </StackPanel>

                    <!-- Right: Shifts -->
                    <materialDesign:Card Grid.Column="2" Padding="20,18"
                                         materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14" LastChildFill="False">
                                <TextBlock Text="משמרות" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" DockPanel.Dock="Right"/>
                                <Button Content="+ הוסף" DockPanel.Dock="Left"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Padding="12,4" FontSize="12" Click="AddShift_Click"/>
                            </DockPanel>

                            <ItemsControl x:Name="ShiftsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>   <!-- badge -->
                                                <ColumnDefinition Width="*"/>    <!-- name -->
                                                <ColumnDefinition Width="130"/>  <!-- hours -->
                                                <ColumnDefinition Width="28"/>   <!-- up -->
                                                <ColumnDefinition Width="28"/>   <!-- down -->
                                                <ColumnDefinition Width="28"/>   <!-- delete -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Order badge -->
                                            <Border Grid.Column="0" Background="{StaticResource HoverBrush}"
                                                    CornerRadius="5" Width="24" Height="24"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding OrderNumber}" FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Shift name -->
                                            <TextBox Grid.Column="1" Margin="6,0"
                                                     Text="{Binding ShiftName, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="שם משמרת"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     FontSize="12"/>

                                            <!-- Hours -->
                                            <TextBox Grid.Column="2" Margin="0,0,6,0"
                                                     Text="{Binding ShiftHours, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="07:00-15:00"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     FontSize="12"/>

                                            <!-- Move up -->
                                            <Button Grid.Column="3"
                                                    Style="{StaticResource TinyIconBtn}"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Tag="{Binding}" Click="MoveShiftUp_Click"
                                                    ToolTip="הזז למעלה">
                                                <materialDesign:PackIcon Kind="ChevronUp" Width="18" Height="18"/>
                                            </Button>

                                            <!-- Move down -->
                                            <Button Grid.Column="4"
                                                    Style="{StaticResource TinyIconBtn}"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Tag="{Binding}" Click="MoveShiftDown_Click"
                                                    ToolTip="הזז למטה">
                                                <materialDesign:PackIcon Kind="ChevronDown" Width="18" Height="18"/>
                                            </Button>

                                            <!-- Delete -->
                                            <Button Grid.Column="5"
                                                    Style="{StaticResource TinyIconBtn}"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    Tag="{Binding}" Click="RemoveShift_Click">
                                                <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="פורמט שעות: 07:00-15:00 / 23:00-07:00 ללילה"
                                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </materialDesign:Card>

                </Grid>

                <!-- ── Bottom: Live preview (full width) ── -->
                <StackPanel>

                    <!-- Preview label row -->
                    <DockPanel Margin="0,0,0,10">
                        <materialDesign:PackIcon Kind="Eye" DockPanel.Dock="Right"
                                                 Foreground="{StaticResource PrimaryBrush}"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="תצוגה מקדימה — כך תיראה הטבלה"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   DockPanel.Dock="Right"/>
                        <TextBlock Text="(הטבלה תיראה זהה בעת ההדפסה)"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Preview card -->
                    <Border x:Name="PreviewWrapper"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="16" ClipToBounds="True">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ContentPresenter x:Name="PreviewHost"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Legend -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Border Background="#3B82F6" CornerRadius="3" Width="14" Height="14"
                                VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="כותרות ימים" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"
                                   VerticalAlignment="Center"/>
                        <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                CornerRadius="3" Width="14" Height="14"
                                VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="שם משמרת" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"
                                   VerticalAlignment="Center"/>
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="3" Width="14" Height="14"
                                VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="תאי שיבוץ" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
