<Page x:Class="WorkSchedule.Views.Pages.PreviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource BackgroundBrush}"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Export buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Click="ExportPng_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Padding="16,10" FontSize="13" FontWeight="SemiBold" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <materialDesign:PackIcon Kind="ImageOutline" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="שמור תמונה" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="ExportExcel_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="16,10" FontSize="13" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="ייצוא Excel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="WhatsAppBtn" Click="ShareWhatsApp_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="16,10" FontSize="13"
                            BorderBrush="#25D366" Foreground="#25D366">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <materialDesign:PackIcon Kind="Whatsapp" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="שתף בוואטסאפ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Title -->
                <StackPanel Grid.Column="1" FlowDirection="RightToLeft"
                            VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock x:Name="ScheduleTitle" Text="תצוגה מקדימה"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="לחץ על משבצת לעריכה — שינויים נשמרים אוטומטית"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Schedule grid ── -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ContentPresenter x:Name="ScheduleGridHost" Margin="24,20"/>
        </ScrollViewer>

        <!-- ── Free text edit overlay ── -->
        <Grid x:Name="TextEditOverlay" Grid.RowSpan="2"
              Visibility="Collapsed" Background="#88000000">
            <materialDesign:Card Width="380" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Padding="28" materialDesign:ElevationAssist.Elevation="Dp8"
                                 FlowDirection="RightToLeft">
                <StackPanel>
                    <TextBlock x:Name="TextEditTitle" Text="עריכת תא"
                               FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBox x:Name="TextEditBox"
                             materialDesign:HintAssist.Hint="שם עובד, הערה חופשית..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,24"
                             KeyDown="TextEditBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="אישור" Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="24,8" Margin="0,0,10,0" Click="TextEditConfirm_Click"/>
                        <Button Content="ביטול" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="24,8" Click="TextEditCancel_Click"/>
                        <Button Content="נקה תא" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource DangerBrush}"
                                BorderBrush="{StaticResource DangerBrush}"
                                Padding="24,8" Margin="10,0,0,0" Click="TextEditClear_Click"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Page>
