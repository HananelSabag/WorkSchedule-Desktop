<Page x:Class="WorkSchedule.Views.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource BackgroundBrush}"
      FlowDirection="RightToLeft">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,32,32,32">

            <!-- Header -->
            <TextBlock Text="דף הבית" FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="ברוך הבא — בוא נסדר את השבוע" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <!-- Setup warning -->
            <Border x:Name="SetupWarningBorder" Visibility="Collapsed"
                    Background="#FEF9C3" BorderBrush="#FDE68A" BorderThickness="1"
                    CornerRadius="8" Padding="16,14" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#92400E"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="SetupWarningText" Text="" FontSize="14"
                                   Foreground="#92400E" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="GoToTemplateBtn" Content="הגדר תבנית טבלה"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#92400E" BorderBrush="#D97706"
                                Visibility="Collapsed" Margin="0,0,8,0"
                                Click="GoToTemplate_Click"/>
                        <Button x:Name="GoToEmployeesBtn" Content="הוסף עובדים"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#92400E" BorderBrush="#D97706"
                                Visibility="Collapsed" Click="GoToEmployees_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- New schedule card -->
            <Border x:Name="NewScheduleBtn" Margin="0,0,0,20"
                    Background="{StaticResource PrimaryBrush}"
                    CornerRadius="4" Cursor="Hand" Padding="28,22"
                    MouseLeftButtonDown="NewSchedule_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.18" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title + subtitle -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="סידור חדש" FontSize="19" FontWeight="Bold"
                                   Foreground="White" FontFamily="Segoe UI"/>
                        <TextBlock Text="פתח סידור עבודה חדש לשבוע הקרוב"
                                   FontSize="13" Foreground="#CCE0FF" FontFamily="Segoe UI"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Icon circle -->
                    <Border Grid.Column="1" Width="52" Height="52"
                            CornerRadius="26" Background="#2563EB" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Plus" Width="28" Height="28"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Stats — 3 equal columns -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0" Margin="0,0,10,0" Padding="24,20"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="AccountGroup" Foreground="{StaticResource PrimaryBrush}"
                                                 Width="28" Height="28"/>
                        <TextBlock x:Name="EmployeesCountLabel" Text="0" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,2"/>
                        <TextBlock Text="עובדים" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="1" Margin="5,0" Padding="24,20"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CalendarCheck" Foreground="{StaticResource SecondaryBrush}"
                                                 Width="28" Height="28"/>
                        <TextBlock x:Name="SchedulesCountLabel" Text="0" FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,2"/>
                        <TextBlock Text="סידורים שמורים" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="2" Margin="10,0,0,0" Padding="24,20"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="ClockOutline" Foreground="{StaticResource WarningBrush}"
                                                 Width="28" Height="28"/>
                        <TextBlock x:Name="LastScheduleLabel" Text="—" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,8,0,2" TextWrapping="Wrap"/>
                        <TextBlock Text="סידור אחרון" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- Recent schedules -->
            <TextBlock Text="סידורים אחרונים" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <Border x:Name="EmptyHistoryHint"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24,20">
                <TextBlock Text="עדיין אין סידורים שמורים. לחץ על '+ סידור חדש' כדי להתחיל."
                           FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </Border>

            <ItemsControl x:Name="RecentSchedulesList" Visibility="Collapsed">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,0,0,8" Padding="16,14"
                                             materialDesign:ElevationAssist.Elevation="Dp1" Cursor="Hand">
                            <DockPanel>
                                <materialDesign:PackIcon Kind="ChevronLeft" DockPanel.Dock="Left"
                                                         Foreground="{StaticResource TextSecondaryBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding WeekStart}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
