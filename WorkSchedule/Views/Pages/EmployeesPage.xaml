<Page x:Class="WorkSchedule.Views.Pages.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource BackgroundBrush}"
      FlowDirection="RightToLeft">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="32,20">
            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="AddEmployee_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Padding="20,10" FontSize="14" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="הוסף עובד" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            Margin="20,0,0,0" FlowDirection="RightToLeft">
                    <TextBlock Text="עובדים" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="SubtitleLabel" Text="טוען..."
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,32">

                <!-- Empty state -->
                <Border x:Name="EmptyState"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="40,60">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="AccountGroupOutline" Width="64" Height="64"
                                                 Foreground="{StaticResource BorderBrush}"
                                                 HorizontalAlignment="Center"/>
                        <TextBlock Text="אין עובדים עדיין" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,16,0,8"/>
                        <TextBlock Text="לחץ על 'הוסף עובד' כדי להתחיל" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="EmployeesList" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- FlowDirection=LeftToRight on the row itself so column order is predictable -->
                            <materialDesign:Card Margin="0,0,0,10"
                                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                                 FlowDirection="LeftToRight">
                                <Grid Margin="16,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>   <!-- Delete -->
                                        <ColumnDefinition Width="120"/>  <!-- Mitgaber toggle -->
                                        <ColumnDefinition Width="120"/>  <!-- Shabbat toggle -->
                                        <ColumnDefinition Width="*"/>    <!-- Name + badges -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Delete (leftmost) -->
                                    <Button Grid.Column="0" VerticalAlignment="Center"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Foreground="{StaticResource DangerBrush}"
                                            ToolTip="מחק עובד" Tag="{Binding}"
                                            Click="DeleteEmployee_Click">
                                        <materialDesign:PackIcon Kind="Delete" Width="20" Height="20"/>
                                    </Button>

                                    <!-- Mitgaber toggle -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="מתגבר" FontSize="11" FlowDirection="RightToLeft"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                      IsChecked="{Binding IsMitgaber}"
                                                      Tag="{Binding}"
                                                      Checked="MitgaberToggle_Changed"
                                                      Unchecked="MitgaberToggle_Changed"/>
                                    </StackPanel>

                                    <!-- Shabbat toggle -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="שומר שבת" FontSize="11" FlowDirection="RightToLeft"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                      IsChecked="{Binding ShabbatObserver}"
                                                      Tag="{Binding}"
                                                      Checked="ShabbatToggle_Changed"
                                                      Unchecked="ShabbatToggle_Changed"/>
                                    </StackPanel>

                                    <!-- Name + badges (rightmost = first in Hebrew reading) -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center"
                                                Margin="12,0,4,0" FlowDirection="RightToLeft">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Border Background="#EEF2FF" CornerRadius="4" Padding="7,2" Margin="0,0,6,0"
                                                    Visibility="{Binding ShabbatObserver, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="שומר שבת" FontSize="11" Foreground="#4F46E5" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="#F0FDF4" CornerRadius="4" Padding="7,2"
                                                    Visibility="{Binding IsMitgaber, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="מתגבר" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Add dialog -->
        <Grid x:Name="DialogOverlay" Grid.RowSpan="2" Visibility="Collapsed"
              Background="#80000000">
            <materialDesign:Card Width="420" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Padding="28" materialDesign:ElevationAssist.Elevation="Dp8"
                                 FlowDirection="RightToLeft">
                <StackPanel>
                    <TextBlock Text="הוסף עובד" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                    <TextBox x:Name="EmployeeNameBox"
                             materialDesign:HintAssist.Hint="שם העובד"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,20"
                             KeyDown="EmployeeNameBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ToggleButton x:Name="DialogShabbatToggle"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      Margin="0,0,12,0"/>
                        <TextBlock Text="שומר שבת" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                        <ToggleButton x:Name="DialogMitgaberToggle"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      Margin="0,0,12,0"/>
                        <TextBlock Text="מתגבר (עד 16 שעות ביום)" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="ביטול" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="24,8" Margin="0,0,10,0" Click="CancelDialog_Click"/>
                        <Button Content="שמור" Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="24,8" Click="SaveEmployee_Click"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Page>
