<Page x:Class="WorkSchedule.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource BackgroundBrush}"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Text="הגדרות" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="מידע על האפליקציה וניהול נתונים"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,32">

                <!-- ── About card ── -->
                <materialDesign:Card Padding="28,24" Margin="0,0,0,20"
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <!-- App logo + name row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Image Source="/Resources/logo.png" Width="56" Height="56"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="סידור עבודה" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="v1.0.0  ·  גרסת Windows"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Separator Margin="0,0,0,20" Background="{StaticResource BorderBrush}"/>

                        <!-- Info rows -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="מפתח" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="חננאל סבג" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="פלטפורמה" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="Windows (.NET 10 / WPF)" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="מסד נתונים" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="DbPathLabel" Grid.Column="1" Text="טוען..."
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="תיאור" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="אפליקציה לניהול סידור עבודה שבועי — שיבוץ ידני, חסימות לפי עובד, ייצוא לתמונה ו-Excel."
                                       FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ── Data management card ── -->
                <materialDesign:Card Padding="28,24"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <TextBlock Text="ניהול נתונים" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                                CornerRadius="8" Padding="16,14" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="מחק את כל הסידורים השמורים"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#991B1B"/>
                                    <TextBlock Text="פעולה זו אינה ניתנת לביטול"
                                               FontSize="12" Foreground="#B91C1C" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="{StaticResource DangerBrush}"
                                        BorderBrush="{StaticResource DangerBrush}"
                                        Padding="14,7" Margin="16,0,0,0"
                                        Click="DeleteAllSchedules_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="מחק הכל" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                CornerRadius="8" Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="מחק טיוטה שמורה"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#92400E"/>
                                    <TextBlock Text="מוחק את הסידור שלא הסתיים שמור בטיוטה"
                                               FontSize="12" Foreground="#B45309" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="{StaticResource WarningBrush}"
                                        BorderBrush="{StaticResource WarningBrush}"
                                        Padding="14,7" Margin="16,0,0,0"
                                        Click="DeleteDraft_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileRemoveOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="מחק טיוטה" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
