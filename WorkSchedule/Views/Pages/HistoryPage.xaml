<Page x:Class="WorkSchedule.Views.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource BackgroundBrush}"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="32,20">
            <StackPanel>
                <TextBlock Text="היסטוריה" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock x:Name="SubtitleLabel" Text="טוען..."
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,32">

                <!-- Empty state -->
                <Border x:Name="EmptyState"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="40,60"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="CalendarBlankOutline" Width="64" Height="64"
                                                 Foreground="{StaticResource BorderBrush}"
                                                 HorizontalAlignment="Center"/>
                        <TextBlock Text="אין סידורים שמורים עדיין" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,16,0,8"/>
                        <TextBlock Text="צור סידור חדש מדף הבית כדי להתחיל"
                                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Schedule list -->
                <ItemsControl x:Name="ScheduleList" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="0,0,0,10"
                                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                                 FlowDirection="LeftToRight">
                                <Grid Margin="20,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Delete -->
                                    <Button Grid.Column="0" VerticalAlignment="Center"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Foreground="{StaticResource DangerBrush}"
                                            ToolTip="מחק סידור" Tag="{Binding}"
                                            Click="DeleteSchedule_Click">
                                        <materialDesign:PackIcon Kind="Delete" Width="20" Height="20"/>
                                    </Button>

                                    <!-- Rename -->
                                    <Button Grid.Column="1" VerticalAlignment="Center"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            ToolTip="שנה שם" Tag="{Binding}"
                                            Click="RenameSchedule_Click">
                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                    </Button>

                                    <!-- Open -->
                                    <Button Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Padding="14,6" FontSize="12"
                                            Tag="{Binding}" Click="OpenSchedule_Click">
                                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                            <materialDesign:PackIcon Kind="Eye" Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="פתח" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Schedule info -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center"
                                                Margin="16,0,0,0" FlowDirection="RightToLeft">
                                        <TextBlock Text="{Binding WeekStart}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding CreatedDateDisplay}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Rename overlay ── -->
        <Grid x:Name="RenameOverlay" Grid.RowSpan="2"
              Visibility="Collapsed" Background="#88000000">
            <materialDesign:Card Width="400" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Padding="28" materialDesign:ElevationAssist.Elevation="Dp8"
                                 FlowDirection="RightToLeft">
                <StackPanel>
                    <TextBlock Text="שינוי שם סידור" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBox x:Name="RenameBox"
                             materialDesign:HintAssist.Hint="שם הסידור..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,24"
                             KeyDown="RenameBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="שמור" Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="24,8" Margin="0,0,10,0" Click="RenameConfirm_Click"/>
                        <Button Content="ביטול" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="24,8" Click="RenameCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

    </Grid>
</Page>
