<Page x:Class="WorkSchedule.Views.Pages.AutoSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource BackgroundBrush}"
      FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Action buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="SaveBtn" Click="Save_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Padding="18,10" FontSize="13" FontWeight="SemiBold"
                            Margin="0,0,8,0" IsEnabled="False">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="שמור והצג" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BackToBlocks_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="18,10" FontSize="13">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <materialDesign:PackIcon Kind="ArrowRight" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="חסימות" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Title -->
                <StackPanel Grid.Column="1" FlowDirection="RightToLeft"
                            VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="שיבוץ אוטומטי" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="המערכת שיבצה עובדים לפי חסימות ואילוצים — ניתן לערוך ידנית לאחר השמירה"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Content ── -->
        <Grid Grid.Row="1">

            <!-- Loading state -->
            <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Foreground="{StaticResource PrimaryBrush}"
                             Margin="0,0,0,16"/>
                <TextBlock Text="מריץ אלגוריתם שיבוץ..." FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Result state -->
            <ScrollViewer x:Name="ResultPanel" Visibility="Collapsed"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20">

                    <!-- Summary card -->
                    <materialDesign:Card Padding="24,20" Margin="0,0,0,16"
                                         materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel>
                            <!-- Status row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16" FlowDirection="RightToLeft">
                                <materialDesign:PackIcon x:Name="StatusIcon" Kind="CheckCircle"
                                                         Width="24" Height="24"
                                                         Foreground="{StaticResource SecondaryBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="StatusLabel"
                                           Text="הסידור הושלם בהצלחה!"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Stats row: 3 boxes -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#F0FDF4" CornerRadius="8" Padding="16,12" Margin="0,0,8,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="FilledCount" Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="#16A34A" HorizontalAlignment="Center"/>
                                        <TextBlock Text="מולאו" FontSize="12"
                                                   Foreground="#15803D" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="#FEF2F2" CornerRadius="8" Padding="16,12" Margin="4,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="EmptyCount" Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="#DC2626" HorizontalAlignment="Center"/>
                                        <TextBlock Text="פתוחות" FontSize="12"
                                                   Foreground="#B91C1C" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#F8FAFC" CornerRadius="8" Padding="16,12" Margin="8,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="TotalCount" Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="סה״כ משמרות" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Impossible shifts warning (hidden when none) -->
                    <Border x:Name="ImpossibleCard" Visibility="Collapsed"
                            Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                            CornerRadius="10" Padding="20,16" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" FlowDirection="RightToLeft">
                                <materialDesign:PackIcon Kind="AlertCircle" Width="20" Height="20"
                                                         Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="משמרות שלא ניתן היה לשבץ:" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#991B1B" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ItemsControl x:Name="ImpossibleList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0" FlowDirection="RightToLeft">
                                            <materialDesign:PackIcon Kind="CircleSmall" Width="16" Height="16"
                                                                     Foreground="#DC2626" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding}" FontSize="13"
                                                       Foreground="#7F1D1D" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="ניתן לערוך ידנית לאחר השמירה"
                                       FontSize="12" Foreground="#B91C1C" Margin="0,10,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <!-- Schedule preview grid -->
                    <ContentPresenter x:Name="ScheduleGridHost"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ── Save name overlay ── -->
        <Grid x:Name="SaveOverlay" Grid.RowSpan="2"
              Visibility="Collapsed" Background="#88000000">
            <materialDesign:Card Width="400" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Padding="28" materialDesign:ElevationAssist.Elevation="Dp8"
                                 FlowDirection="RightToLeft">
                <StackPanel>
                    <TextBlock Text="שמירת סידור אוטומטי" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Text="הכנס שם לסידור (לדוגמה: שבוע 20/04 - 26/04)"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>
                    <TextBox x:Name="SaveNameBox"
                             materialDesign:HintAssist.Hint="שם הסידור..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Margin="0,0,0,24"
                             KeyDown="SaveNameBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="שמור" Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="24,8" Margin="0,0,10,0" Click="SaveConfirm_Click"/>
                        <Button Content="ביטול" Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="24,8" Click="SaveCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

    </Grid>
</Page>
